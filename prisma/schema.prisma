generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

/// Real-world person represented in the relationship graph.
model Person {
  id          String   @id @default(uuid())
  displayName String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  users       User[]
  trackedBy   Friend[]
  authoredFacts PersonFact[] @relation("AuthoredPersonFacts")
  targetFacts   PersonFact[] @relation("TargetPersonFacts")
}

/// Discrete claim or profile fact about a person, with provenance and trust status.
model PersonFact {
  id                 String   @id @default(uuid())
  targetPersonId     String
  targetPerson       Person   @relation("TargetPersonFacts", fields: [targetPersonId], references: [id])
  authorPersonId     String
  authorPerson       Person   @relation("AuthoredPersonFacts", fields: [authorPersonId], references: [id])
  content            String
  verificationStatus String
  sourceType         String   @default("manual")
  sourceId           String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@index([targetPersonId])
  @@index([authorPersonId])
  @@index([verificationStatus])
}

/// Application user who owns friendship data.
model User {
  id          String   @id @default(uuid())
  personId    String?
  person      Person?  @relation(fields: [personId], references: [id])
  email       String   @unique
  displayName String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  friends     Friend[]

  @@index([personId])
}

/// Person whose friendship state is tracked by the API.
model Friend {
  id                  String               @id @default(uuid())
  ownerUserId         String
  ownerUser           User                 @relation(fields: [ownerUserId], references: [id])
  targetPersonId      String
  targetPerson        Person               @relation(fields: [targetPersonId], references: [id])
  displayName         String
  notes               String?
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  rules               Rule[]
  events              Event[]
  deletedAt           DateTime?
  searchableDocuments SearchableDocument[]

  @@index([ownerUserId])
  @@index([targetPersonId])
}

/// Preference or boundary that affects friendship scoring.
model Rule {
  id              String   @id @default(uuid())
  friendId        String
  friend          Friend   @relation(fields: [friendId], references: [id])
  title           String
  description     String
  impactDirection String
  weight          String
  active          Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

/// Logged interaction or incident that can be manually or LLM-assessed.
model Event {
  id          String       @id @default(uuid())
  friendId    String
  friend      Friend       @relation(fields: [friendId], references: [id])
  eventText   String
  happenedAt  DateTime?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  assessments Assessment[]
}

/// Score impact assigned to an event by a human or LLM provider.
model Assessment {
  id              String   @id @default(uuid())
  eventId         String
  event           Event    @relation(fields: [eventId], references: [id])
  scoreDelta      Float
  reason          String?
  source          String
  impactDirection String?
  biasNotes       String?
  confidence      Float?
  matchedRuleIds  String[] @default([])
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  modelName       String?
  promptVersion   String?
}

/// Denormalized text record used by keyword retrieval and RAG prompts.
model SearchableDocument {
  id             String    @id @default(uuid())
  friendId       String
  friend         Friend    @relation(fields: [friendId], references: [id])
  sourceType     String
  sourceId       String
  content        String
  documentId     String?
  documentTitle  String?
  documentType   String?
  sourceDate     DateTime?
  chunkIndex     Int?
  sectionHeading String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@index([friendId, documentId])
}
